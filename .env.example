# --- Supabase ---
# Created in Phase 1 via Supabase MCP (or manually if MCP unavailable).
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=
SUPABASE_PROJECT_REF=

# --- Anthropic ---
# Set as a Supabase Edge Function secret only — never bundled in the extension.
# Run: supabase secrets set ANTHROPIC_API_KEY=...
ANTHROPIC_API_KEY=

# --- Vite-exposed values (must be prefixed VITE_) ---
# These get bundled into the extension. Use ANON KEY only — never service role.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=

# --- GitHub (optional, used for `gh` CLI fallback) ---
GH_TOKEN=
