# --- Supabase ---
# Created in Phase 1 via Supabase MCP (or manually if MCP unavailable).
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=
SUPABASE_PROJECT_REF=

# --- OpenRouter ---
# Single LLM gateway for all three Edge Functions. Set as a Supabase secret
# only — never bundled in the extension. Sign up at https://openrouter.ai.
# Run: supabase secrets set OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_API_KEY=

# Optional per-task model overrides. Defaults are sensible — only set these
# if you want to switch models without redeploying code.
# OPENROUTER_MODEL_COACH=anthropic/claude-haiku-4.5
# OPENROUTER_MODEL_TRANSCRIBE=google/gemini-2.5-flash
# OPENROUTER_MODEL_SKILL=anthropic/claude-opus-4.5

# --- Vite-exposed values (must be prefixed VITE_) ---
# These get bundled into the extension. Use ANON KEY only — never service role.
#
# Scout's data project — owns recordings, events, skills, storage buckets,
# and the three Edge Functions (coach, transcribe, generate-skill).
VITE_SUPABASE_URL=https://YOUR_DATA_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=
#
# Optional: dedicated universal-auth project, shared across Orage apps.
# Leave both blank to run in single-project mode (auth and data share the
# same Supabase project). When you DO set these, the data project's JWT
# secret must equal the auth project's JWT secret — see README §Universal
# login — and apply migration 0002_universal_auth.sql.
VITE_AUTH_SUPABASE_URL=
VITE_AUTH_SUPABASE_ANON_KEY=

# --- GitHub (optional, used for `gh` CLI fallback) ---
GH_TOKEN=
