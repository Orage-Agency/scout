{
  "manifest_version": 3,
  "name": "Scout",
  "version": "0.2.4",
  "description": "Capture workflows. Generate skill files for AI agents.",
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "Scout"
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "permissions": [
    "activeTab",
    "alarms",
    "tabs",
    "scripting",
    "storage",
    "offscreen",
    "clipboardRead",
    "webNavigation",
    "notifications",
    "nativeMessaging"
  ],
  "host_permissions": ["<all_urls>"],
  "web_accessible_resources": [
    {
      "resources": [
        "src/offscreen/index.html",
        "src/device-approve/index.html",
        "assets/*"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "commands": {
    "toggle-recording": {
      "suggested_key": {
        "default": "Alt+Shift+R"
      },
      "description": "Start or stop recording"
    }
  },
  "icons": {
    "16": "public/icons/icon-16.png",
    "32": "public/icons/icon-32.png",
    "48": "public/icons/icon-48.png",
    "128": "public/icons/icon-128.png"
  }
}
